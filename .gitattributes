# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf

# Config / Data
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.env text eol=lf
*.env.example text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Docs / Templates
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - no diff, no merge, no eol conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.whl binary
*.pyc binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary
*.db binary
*.sqlite binary
*.sqlite3 binary
